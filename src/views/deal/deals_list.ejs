<%- include('../partials/components/header.ejs'); %>
<%- include('../partials/components/top-bar.ejs'); %>
<%- include('../partials/components/sidebar.ejs'); %>


  <main id="main" class="main">

    <div class="pagetitle">
      <h1>Deals</h1>
      <nav>
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/portal/deal">Deal</a></li>
          <li class="breadcrumb-item"><a class="active" href="/portal/deal">Deal List</a></li>
        </ol>
      </nav>
    </div>

    <section class="section">
      <div class="row">
        <div class="col-lg-12">

          <div class="card">
            <div class="card-body">
              <div class="row">
                <div class="col-sm-2">
                  <h5 class="card-title">Deals</h5>
                </div>
                <div class="col-sm-6">
                  <form method="GET" action="">
                  <div class="row mb-3">
                    <div class="col-md-4">
                      <label for="city_filter" class="form-label">Filter by City</label>
                      <select class="form-select" id="city_filter" name="city">
                        <option value="">-- Select City --</option>

                          <% cities.forEach(city => { %>
                            <option 
                              value="<%= city.id %>" 
                              <%= city.id == selectedCity ? "selected" : "" %>>
                              <%= city.name %>
                            </option>
                          <% }) %>

                      </select>
                    </div>

                    <div class="col-md-2 d-flex align-items-end">
                      <button class="btn btn-primary w-100" id="filter_city_btn">
                        Search
                      </button>
                    </div>
                  </div>
                  </form>
                </div>
              </div>

              <table class="table datatable" id="cities_table">
                <thead>
                  <tr>
                    <th scope="col">#</th>
                    <th scope="col">Hotel</th>
                    <th scope="col">Room</th>
                    <th scope="col">Room Occupancy</th>
                    <th scope="col">Deal Title</th>
                    <th scope="col">Deal Price</th>
                    <th scope="col">Actual Price</th>
                    <th scope="col">Start Date</th>
                    <th scope="col">End Date</th>
                    <th scope="col">Status</th>
                    <th scope="col">Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% let index = 1 %>
                  <% deals.forEach((d) => { %>
                    <tr>
                      <td><%= index %></td>

                      <!-- Hotel name -->
                      <td><%= d.hotel_name || "-" %></td>

                      <!-- Room name -->
                      <td><%= d.room_name || "-" %></td>

                      <!-- Room Occupancy -->
                      <td><%= d.occupancy_name || "-" %></td>

                      <!-- Deal Title -->
                      <td><%= d.deal_title %></td>

                      <!-- Prices -->
                      <td><span class="badge bg-warning"><%= d.deal_deal_price %></span></td>
                      <td><%= d.deal_actual_price %></td>

                      <!-- Dates -->
                      <td><%= d.deal_start_date %></td>
                      <td><%= d.deal_end_date %></td>

                      <!-- Status -->
                      <td>
                        <% if (d.deal_status === 'active') { %>
                          <span class="badge bg-success">Active</span>
                        <% } else { %>
                          <span class="badge bg-danger">Inactive</span>
                        <% } %>
                      </td>

                      <!-- Action buttons -->
                      <td>
                        <a href="/portal/deal/<%= d.deal_id %>/edit" class="btn btn-sm btn-primary">Edit</a>

                        <form action="/portal/deal/<%= d.deal_id %>/delete" method="POST" style="display:inline;">
                          <button class="btn btn-sm btn-danger delete_deal" data-id="<%= d.deal_id %>">Delete</button>
                        </form>
                      </td>
                    </tr>
                    <% index++ %>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>

<button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#transModal" id="tanslate_button" style="display: none;">
    Launch demo modal
</button>

  <div class="modal fade" id="transModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Series <span class="lang_text">Spanish</span> Translation</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form>
                    <input type="text" id="series_id" class="form-control" name="series_id"  disabled style="display: none;" />
                    <input type="text" id="lang_code" class="form-control" name="lang_code"  disabled style="display: none;"  />
                    <div class="form-outline mb-4">
                        <label class="form-label" for="parentlang">Original English</label>
                      <input type="text" id="parentlang" class="form-control" name="parentlang"  disabled />
                    </div>
                  
                    <div class="form-outline mb-4">
                        <label class="form-label" for="slug">Translate To <span class="lang_text"></span></label>
                      <input type="text" class="form-control" name="tran_lang" id="tran_lang" />
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-primary">Save changes</button>
                    </div>

                    <div class="loader-container" id="loader-container" style="display: none;">
                        <div class="loader"></div>
                    </div>
                </form>
            </div>
            
        </div>
    </div>
</div>
<%- include('../partials/components/footer.ejs'); %>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>


<script>
    $(document).on("click", ".delete_deal", function (e) {
      e.preventDefault();
      Swal.fire({
        title: 'Are you sure?',
        text: "You won't be able to revert this!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#3085d6',
        cancelButtonColor: '#d33',
        confirmButtonText: 'Yes, delete it!'
      }).then((result) => {
        if (result.isConfirmed) {
          var id = $(this).data("id");
          var current_ele = $(this);
          $.ajax({
            type: "POST", // Change to "POST" or "PUT" if needed
            url: `/portal/deal/${id}/delete/`, // Replace with your API endpoint
            success: function (response) {
              // Handle the success response here
              console.log("Success:", response);
              if (response.status == "success") {
                Swal.fire(
                  'Deleted!',
                  'Deal has been deleted.',
                  'success'
                )
                current_ele.parent().parent().hide();
                location.reload();
              } else {
                console.log("some error occure =====");
              }
            },
            error: function (error) {
              // Handle the error response here
              console.log("Error:", error);
            },
          });
        }
      })
    });
</script>

</body>

</html>
