<%- include('../partials/components/header.ejs'); %>
<%- include('../partials/components/top-bar.ejs'); %>
<%- include('../partials/components/sidebar.ejs'); %>


  <main id="main" class="main">

    <div class="pagetitle">
      <h1>City</h1>
      <nav>
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/portal/contacts">Contact Us</a></li>
          <li class="breadcrumb-item"><a class="active" href="/portal/contacts">Contact Us List</a></li>
        </ol>
      </nav>
    </div>

    <section class="section">
      <div class="row">
        <div class="col-lg-12">

          <div class="card">
            <div class="card-body">
              <h5 class="card-title">Contacts</h5>

              <table class="table datatable" id="cities_table">
                <thead>
                  <tr>
                    <th scope="col">#</th>
                    <th scope="col">Name</th>
                    <th scope="col">Email</th>
                    <th scope="col">Phone</th>
                    <th scope="col">Description</th>
                    <th scope="col">Status</th>
                    <th scope="col">Date</th>
                    <th scope="col">Action</th>
                  </tr>
                </thead>
                <tbody>
                    <% let index = 1 %>
                    <% contacts.forEach((item) => { %>
                        <tr>
                            <td><%= index %></td>
                            <td>
                                <%= item.name %>
                            </td>
                            <td>
                                <%= item.email %>
                            </td>
                            <td>
                                <%= item.phone %>
                            </td>
                            <td>
                                <%= item.description %>
                            </td>
                            <td>
                                <%= item.status %>
                            </td>
                            <td>
                                <%= new Date(item.createdAt).toLocaleDateString('en-US', { 
                          month: 'short', 
                          day: 'numeric', 
                          year: 'numeric' 
                        }) %>
                            </td>
                            <td>
                               
                                <form action="/portal/contact/<%= item.id %>/delete" method="POST" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-danger delete_contact" data-id="<%= item.id %>">Delete</button>
                                </form>
                            </td>
                        </tr>
                        <% index++ %>
                    <% }) %>
                </tbody>
              </table>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>
  
<%- include('../partials/components/footer.ejs'); %>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    $(document).on("click", ".delete_contact", function (e) {
    e.preventDefault();
    Swal.fire({
      title: 'Are you sure?',
      text: "You won't be able to revert this!",
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#3085d6',
      cancelButtonColor: '#d33',
      confirmButtonText: 'Yes, delete it!'
    }).then((result) => {
      if (result.isConfirmed) {
        var id = $(this).data("id");
        var current_ele = $(this);
        $.ajax({
          type: "POST", // Change to "POST" or "PUT" if needed
          url: `/portal/contact/${id}/delete`, // Replace with your API endpoint
          success: function (response) {
            // Handle the success response here
            console.log("Success:", response);
            if (response.status == "success") {
              Swal.fire(
                'Deleted!',
                'city has been deleted.',
                'success'
              )
              current_ele.parent().parent().hide();
              location.reload();
            } else {
              console.log("some error occure =====");
            }
          },
          error: function (error) {
            // Handle the error response here
            console.log("Error:", error);
          },
        });
      }
    })
  });
</script>

</body>

</html>
