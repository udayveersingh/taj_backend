<%- include('../partials/components/header.ejs'); %>
<%- include('../partials/components/top-bar.ejs'); %>
<%- include('../partials/components/sidebar.ejs'); %>

<main id="main" class="main">

  <div class="pagetitle">
    <h1>Season Codes</h1>
    <nav>
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/portal/season">Season</a></li>
        <li class="breadcrumb-item active">Season List</li>
      </ol>
    </nav>
  </div>

  <section class="section">
    <div class="row">
      <div class="col-lg-12">

        <div class="card">
          <div class="card-body">
            <h5 class="card-title d-flex justify-content-between align-items-center">
              Season Codes
              <a href="/portal/season/add" class="btn btn-primary btn-sm">+ Add Season Code</a>
            </h5>

            <table class="table datatable" id="season_table">
              <thead>
                <tr>
                  <th scope="col">#</th>
                  <th scope="col">Season Code</th>
                  <th scope="col">Name</th>
                   <th scope="col">Description</th>
                  <th scope="col">Start Date</th>
                  <th scope="col">End Date</th>
                  <th scope="col">Action</th>
                </tr>
              </thead>

              <tbody>
                <% let index = 1; %>
                <% seasonCodes.forEach((item) => { %>
                  <tr>
                    <td><%= index %></td>

                    <td><%= item.season_code_id %></td>

                    <td><%= item.name %></td>
                    <td><%= item.description %></td>
                    <td><%= item.start_date_formatted %></td>
                     <td><%= item.end_date_formatted %></td>

                    <td>
                      <a href="/portal/season/<%= item.id %>/edit" class="btn btn-sm btn-primary">
                        Edit
                      </a>

                      <form 
                        action="/portal/season/delete/<%= item.id %>" 
                        method="POST" 
                        style="display:inline;"
                      >
                        <button 
                          type="submit" 
                          class="btn btn-sm btn-danger"
                          onclick="return confirm('Are you sure you want to delete this season code?');"
                        >
                          Delete
                        </button>
                      </form>
                    </td>
                  </tr>
                  <% index++; %>
                <% }) %>
              </tbody>
            </table>

          </div>
        </div>

      </div>
    </div>
  </section>

</main>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<%- include('../partials/components/footer.ejs'); %>

</body>
</html>
