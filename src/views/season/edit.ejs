<%- include('../partials/components/header.ejs'); %>
<%- include('../partials/components/top-bar.ejs'); %>
<%- include('../partials/components/sidebar.ejs'); %>

<main id="main" class="main">
  <div class="pagetitle">
    <h1>Edit Season Code</h1>
    <nav>
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/portal/season">Season Codes</a></li>
        <li class="breadcrumb-item active">Edit Season</li>
      </ol>
    </nav>
  </div><!-- End Page Title -->

  <section class="section">
    <div class="row">
      <div class="col-lg-12">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title">Edit Season</h5>

            <form action="/portal/season/update/<%= season.id %>" method="POST">
              <div class="row">
                    <div class="col-sm-8">
              <div class="form-floating mb-4">
                <input 
                  type="text" 
                  class="form-control border-gray" 
                  id="season_code_id" 
                  name="season_code_id" 
                  placeholder="Season Code ID" 
                  value="<%= season.season_code_id %>" 
                  required
                >
                <label for="season_code_id">Season Code ID</label>
              </div>

              <div class="form-floating mb-4">
                <input 
                  type="text" 
                  class="form-control border-gray" 
                  id="name" 
                  name="name" 
                  placeholder="Season Name" 
                  value="<%= season.name %>" 
                  required
                >
                <label for="name">Season Name</label>
              </div>

                <div class="form-floating mb-4">
                                <textarea class="form-control border-gray" id="description" rows="4" name="description" style="height: 100px;"><%= season.description %></textarea>
                                <label class="form-label" for="description">Description</label>
                            </div>
</div>
                    <div class="col-sm-4">
              <div class="form-outline mb-4">
                <label class="form-label" for="start_date">Start Date</label>
                <input 
                  type="date" 
                  class="form-control border-gray" 
                  id="start_date" 
                  name="start_date" 
                  value="<%= season.start_date_formatted || season.start_date %>" 
                  required
                >
              </div>

              <div class="form-outline mb-4">
                <label class="form-label" for="end_date">End Date</label>
                <input 
                  type="date" 
                  class="form-control border-gray" 
                  id="end_date" 
                  name="end_date" 
                  value="<%= season.end_date_formatted || season.end_date %>" 
                  required
                >
              </div>
                  </div>
                </div>

              <button type="submit" class="btn btn-primary btn-block mb-4">Update Season</button>
            </form>

          </div>
        </div>
      </div>
    </div>
  </section>
</main><!-- End #main -->

<%- include('../partials/components/footer.ejs'); %>
