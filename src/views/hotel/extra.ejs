<%- include('../partials/components/header.ejs'); %>
<%- include('../partials/components/top-bar.ejs'); %>
<%- include('../partials/components/sidebar.ejs'); %>


  <main id="main" class="main">

    <div class="pagetitle">
      <h1>Hotel</h1>
      <nav>
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/portal/hotel">Hotel</a></li>
          <li class="breadcrumb-item"><a class="active" href="/portal/hotel">Hotel List</a></li>
        </ol>
      </nav>
    </div>

    <section class="section">
        <div class="d-flex">
          <div id="edit_video" class="card-title cursor_pointer">Hotel Services</div>
          <div id="complete_video" class="card-title ms-4 cursor_pointer">Hotel Amenities</div>
          <div id="video_users" class="card-title ms-4 cursor_pointer">Nearby Places</div>
           <div class="ms-5">
            <a href="/portal/hotel-extra/add" class="btn btn-sm btn-primary">Add Hotel Extra</a>
          </div>
        </div>

       
      <div class="row" id="show_edit_video">
        <div class="col-lg-12">

          <div class="card">
            <div class="card-body">
              <h5 class="card-title">Hotel Services</h5>

              <table class="table datatable hotel_table_extra" id="hotel_table_extra">
                <thead>
                  <tr>
                    <th scope="col">#</th>
                    <th scope="col">Name</th>
                    <th scope="col">Thumbnail</th>
                    <th scope="col">Action</th>
                  </tr>
                </thead>
                <tbody>
                    <% let index = 1 %>
                    <% hotel_services.forEach((item) => { %>
                        <tr>
                            <td><%= index %></td>
                            <td>
                                <%= item.name %>
                            </td>
                            <td>
                                <% if (item.thumbnail) { %>
                                    <%- item.thumbnail %>  
                                <% } %>
                            </td>
                            <td>
                                <a href="/portal/hotel-extra/edit/<%= item.id %>" class="btn btn-sm btn-primary">Edit</a>
                                <form action="/portal/hotel-extra/<%= item.id %>/delete" method="POST" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                        <% index++ %>
                    <% }) %>
                </tbody>
              </table>
            </div>
          </div>

        </div>
      </div>

      <div class="row" id="show_complete_video" style="display: none;">
        <div class="col-lg-12">

          <div class="card">
            <div class="card-body">
              <h5 class="card-title">Hotel Amenities</h5>

              <table class="table datatable hotel_table_extra">
                <thead>
                  <tr>
                    <th scope="col">#</th>
                    <th scope="col">Name</th>
                    <th scope="col">Thumbnail</th>
                    <th scope="col">Action</th>
                  </tr>
                </thead>
                <tbody>
                    <% let index2 = 1 %>
                    <% hotel_amenities.forEach((item) => { %>
                        <tr>
                            <td><%= index2 %></td>
                            <td>
                                <%= item.name %>
                            </td>
                            <td>
                                 <% if (item.thumbnail) { %>
                                    <%- item.thumbnail %>  
                                <% } %>
                            </td>
                            <td>
                                <a href="/portal/hotel-extra/edit/<%= item.id %>" class="btn btn-sm btn-primary">Edit</a>
                                <form action="/portal/hotel-extra/<%= item.id %>/delete" method="POST" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                        <% index2++ %>
                    <% }) %>
                </tbody>
              </table>
            </div>
          </div>

        </div>
      </div>

      <div class="row" id="show_logged_video_users" style="display: none;">
        <div class="col-lg-12">

          <div class="card">
            <div class="card-body">
              <h5 class="card-title">Nearby Places</h5>

              <table class="table datatable hotel_table_extra">
                <thead>
                  <tr>
                    <th scope="col">#</th>
                    <th scope="col">Name</th>
                    <th scope="col">Thumbnail</th>
                    <th scope="col">Action</th>
                  </tr>
                </thead>
                <tbody>
                    <% let index3 = 1 %>
                    <% hotel_nearby_places.forEach((item) => { %>
                        <tr>
                            <td><%= index3 %></td>
                            <td>
                                <%= item.name %>
                            </td>
                            <td>
                                 <% if (item.thumbnail) { %>
                                    <%- item.thumbnail %>  
                                <% } %>
                            </td>
                            <td>
                                <a href="/portal/hotel-extra/edit/<%= item.id %>" class="btn btn-sm btn-primary">Edit</a>
                                <form action="/portal/hotel-extra/<%= item.id %>/delete" method="POST" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                        <% index3++ %>
                    <% }) %>
                </tbody>
              </table>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>


 
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <%- include('../partials/components/footer.ejs'); %>


<script>
$(document).ready(function(){

    $("#complete_video").click(function(){
      $("#show_complete_video").show();
      $("#show_edit_video").hide();
      $("#show_logged_video_users").hide();
    });

    $("#edit_video").click(function(){
      $("#show_complete_video").hide();
      $("#show_logged_video_users").hide();
      $("#show_edit_video").show();
    });

    $("#video_users").click(function(){
      $("#show_complete_video").hide();
      $("#show_edit_video").hide();
      $("#show_logged_video_users").show();
    });
});
</script>

</body>

</html>
