<%- include('../partials/components/header.ejs'); %>
<%- include('../partials/components/top-bar.ejs'); %>
<%- include('../partials/components/sidebar.ejs'); %>

<main id="main" class="main">
  <div class="pagetitle">
    <h1>Hotel Markup Rates</h1>
  </div>

  <section class="section">
    <div class="card">
      <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mt-3 mb-3">
          <h5 class="card-title mb-0">Manage Hotel Markups</h5>
          <div>
            <button id="editBtn" class="btn btn-warning" onclick="enableEdit()">Edit</button>
            <button id="cancelBtn" class="btn btn-secondary d-none" onclick="location.reload()">Cancel</button>
          </div>
        </div>

        <form method="POST" action="/portal/currency/hotel-markup-rates/update" id="markupForm">

          <div class="table-responsive">
            <table class="table table-bordered table-hover">
              <thead class="table-dark">
                <tr>
                  <th style="width:10%">Hotel ID</th>
                  <th style="width:30%">Hotel Name</th>
                  <th style="width:20%">Fee Buffer Rate</th>
                  <th style="width:20%">Profit Margin Rate</th>
                  <th style="width:20%">Total Markup Rate</th>
                </tr>
              </thead>
              <tbody>
                <% rates.forEach((rate, index) => { %>
                  <tr>
                    <td>
                      <%= rate.hotel.name_id || "" %>
                      <% if (rate.id) { %>
                        <input type="hidden" name="rates[<%= index %>][id]" value="<%= rate.id %>">
                      <% } %>

                      <input type="hidden" name="rates[<%= index %>][hotel_id]" value="<%= rate.hotel.id %>">

                    </td>

                    <td><%= rate.hotel.name %></td>

                    <td>
                      <span class="view-text"><%= rate.fee_buffer_rate %></span>
                      <input type="number" step="0.01"
                        name="rates[<%= index %>][fee_buffer_rate]"
                        value="<%= rate.fee_buffer_rate %>"
                        class="form-control edit-input d-none" required>
                    </td>

                    <td>
                      <span class="view-text"><%= rate.profit_margin_rate %></span>
                      <input type="number" step="0.01"
                        name="rates[<%= index %>][profit_margin_rate]"
                        value="<%= rate.profit_margin_rate %>"
                        class="form-control edit-input d-none" required>
                    </td>

                    <td>
                      <span class="view-text"><%= rate.total_markup_rate %></span>
                      <input type="number" step="0.01"
                        name="rates[<%= index %>][total_markup_rate]"
                        value="<%= rate.total_markup_rate %>"
                        class="form-control edit-input d-none" required>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <div class="mt-3 d-none" id="saveBox">
            <button class="btn btn-primary btn-lg">
              Save Changes
            </button>
          </div>

        </form>
      </div>
    </div>
  </section>
</main>

<script>
function enableEdit() {
  document.querySelectorAll('.view-text').forEach(el => el.classList.add('d-none'));
  document.querySelectorAll('.edit-input').forEach(el => el.classList.remove('d-none'));

  document.getElementById('editBtn').classList.add('d-none');
  document.getElementById('cancelBtn').classList.remove('d-none');
  document.getElementById('saveBox').classList.remove('d-none');
}
</script>

<%- include('../partials/components/footer.ejs'); %>
