<%- include('../partials/components/header.ejs'); %>
<%- include('../partials/components/top-bar.ejs'); %>

<style>
  .rounded-image {
    width: 100px;
    height: 100px;
    object-fit: cover;
    border-radius: 8px;
  }
  .remove-field {
    position: absolute;
    top: -5px;
    right: -5px;
    width: 25px;
    height: 25px;
    padding: 0;
    font-size: 12px;
  }
</style>

<%- include('../partials/components/sidebar.ejs'); %>

<main id="main" class="main">
  <div class="pagetitle">
    <h1>Edit Room</h1>
    <nav>
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/portal/Room">Room</a></li>
        <li class="breadcrumb-item active">Edit Room</li>
      </ol>
    </nav>
  </div><!-- End Page Title -->

  <section class="section">
    <div class="d-flex">
        <div id="edit_video" class="card-title cursor_pointer">Edit Room</div>
        <div id="complete_video" class="card-title ms-4 cursor_pointer">Rooms Occupancy Option</div>
          <div class="ms-5">
          <a href="/portal/room-option/add?hotelId=<%= room.hotel_id %>&roomId=<%= room.id %>" class="btn btn-sm btn-primary">Add Room Occupancy Option</a>
        </div>
    </div>

    <div class="row" id="show_edit_video">
      <div class="col-lg-12">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title">Edit Room</h5>

            <!-- Room Edit Form -->
            <form action="/portal/room/update/<%= room.id %>" method="POST" enctype="multipart/form-data">
              <div class="row">
                <div class="col-sm-8">
                   <div class="form-floating mb-4">
                    <input type="text" class="form-control border-gray" id="room_name_id" name="room_name_id" placeholder="Room Id (required)" value="<%= room.room_name_id %>">
                    <label for="room_name_id">Room Id (required)</label>
                  </div>

                  <div class="form-floating mb-4">
                    <input type="text" class="form-control border-gray" id="name" name="name" placeholder="Name (required)" value="<%= room.name %>">
                    <label for="name">Name (required)</label>
                  </div>

                  <div class="form-floating mb-4">
                    <select id="hotel_id" class="form-select border-gray" aria-label="Hotel" name="hotel_id">
                      <option value="">Select Hotel</option>
                      <% hotels.forEach((item)=>{ %>
                        <option value="<%= item.id %>" <%= room.hotel_id === item.id ? "selected" : "" %>><%= item.name %></option>
                      <% }) %>
                    </select>
                    <label class="form-label" for="hotel">Select Hotel</label>
                  </div>

                  <!-- <div class="form-floating mb-4">
                    <textarea class="form-control border-gray" id="description" rows="4" name="description" style="height: 100px;"><%= room.description || '' %></textarea>
                    <label class="form-label" for="description">Description</label>
                  </div> -->

                  <!-- Thumbnail Upload -->
                  <div class="form-outline mb-4">
                    <label class="form-label label-gray" for="thumbnail_input">Thumbnail</label>
                    <div style="display: flex; gap: 10px; align-items: flex-start;">
                      <div>
                        <label class="image-container-empty" for="thumbnail_input">
                          <i class="bi bi-file-image"></i>
                          <span>Change Image</span>
                        </label>
                        <input type="file" id="thumbnail_input" name="image" accept="image/*" style="display:none;" />
                      </div>

                      <!-- Preview area -->
                      <% if (room.image_url) { %>
                      <div class="image-container" id="thumbnail_preview">
                          <img src="<%= room.image_url %>" alt="Room Thumbnail" class="rounded-image" />
                          <button class="btn btn-danger remove-field" type="button" id="remove_thumbnail_btn">X</button>
                      </div>
                      <% } else { %>
                      <div class="image-container" id="thumbnail_preview"></div>
                      <% } %>
                    </div>
                    <input type="hidden" id="remove_thumbnail" name="remove_thumbnail" value="0" />
                  </div>

                  <!-- Gallery Upload -->
                  <div class="form-outline mb-4">
                    <label class="form-label label-gray" for="gallery_images_input">Gallery Images</label>
                    <div style="display: flex; flex-wrap: wrap; gap: 10px; align-items: flex-start;" id="gallery_preview_container">
                      <label class="image-container-empty" for="gallery_images_input" id="gallery_images_label">
                        <i class="bi bi-images"></i>
                        <span>Add Images</span>
                      </label>
                      <input 
                        type="file" 
                        id="gallery_images_input" 
                        name="gallery_images" 
                        multiple 
                        accept="image/*" 
                        style="display:none;"
                      />

                      <% if (room.photos && room.photos.length > 0) { %>
                          <% room.photos.forEach((photo) => { %>
                          <div class="image-container existing-image" data-photo-id="<%= photo.id %>">
                              <img src="<%= photo.image_url %>" alt="Room Gallery Image" class="rounded-image"   loading="lazy" />
                              <button class="btn btn-danger remove-field remove-existing-image" type="button" data-photo-id="<%= photo.id %>">X</button>
                          </div>
                          <% }) %>
                      <% } %>
                    </div>
                    <input type="hidden" id="deleted_photos" name="deleted_photos" value="" />
                  </div>

                  <!-- Room Extras -->
                  <div class="form-outline mb-4">
                    <label class="form-label">Room Extras</label>
                    <div id="extras-container">
                      <% if (room_extras && room_extras.length > 0) { %>
                        <% room_extras.forEach((extra, index) => { %>
                          <div class="extra-item mb-2" data-extra-id="<%= extra.id %>">
                            <input type="hidden" name="extras[<%= index %>][id]" value="<%= extra.id %>" />
                            <input type="text" name="extras[<%= index %>][name]" placeholder="Extra name" class="form-control d-inline-block w-50" value="<%= extra.name %>" />
                            <input type="number" step="0.01" name="extras[<%= index %>][price]" placeholder="Price" class="form-control d-inline-block w-25" value="<%= extra.price %>" />
                            <button type="button" class="btn btn-sm btn-danger remove-extra-btn">×</button>
                          </div>
                        <% }) %>
                      <% } else { %>
                        <div class="extra-item mb-2">
                          <input type="text" name="extras[0][name]" placeholder="Extra name" class="form-control d-inline-block w-50" />
                          <input type="number" step="0.01" name="extras[0][price]" placeholder="Price" class="form-control d-inline-block w-25" />
                        </div>
                      <% } %>
                    </div>
                    <button type="button" class="btn btn-outline-secondary" id="add-extra-btn">+ Add Extra</button>
                    <input type="hidden" id="deleted_extras" name="deleted_extras" value="" />
                  </div>
                </div>

                <div class="col-sm-4">
                  <!-- Maximum Guest -->
                  <!-- <div class="form-outline mb-4">
                    <label class="form-label" for="maximum_guest">Maximum Guest</label>
                    <input type="text" id="maximum_guest" class="form-control" name="maximum_guest" value="<%= room.max_guests || '' %>" />
                  </div> -->

                   <div class="form-floating mb-4">
                    <select id="roomTypeId" class="form-select border-gray" aria-label="Hotel" name="roomTypeId">
                      <option value="">Select Room Type</option>
                      <% room_types.forEach((item)=>{ %>
                        <option value="<%= item.id %>" 
                          <%= room.room_type_id === item.id ? "selected" : "" %>>
                          <%= item.name %>
                        </option>

                      <% }) %>
                    </select>
                    <label class="form-label" for="roomTypeId">Select Room Type</label>
                  </div>

                  <!-- Bed Type -->
                  <!-- <div class="form-outline mb-4">
                    <label class="form-label" for="bed_type">Bed Type</label>
                    <input type="text" id="bed_type" class="form-control" name="bed_type" value="<%= room.bed_type || '' %>" />
                  </div> -->

                   <div class="mb-4 form-outline">
                    <label class="form-label">View from Room</label>
                    <div>
                      <% viewOptions.forEach((option, index) => { %>
                        <div class="form-check">
                          <input 
                            class="form-check-input" 
                            type="checkbox" 
                            id="view_<%= index %>" 
                            name="view_from_room[]" 
                            value="<%= option %>"
                            <% if (room.view_from_room.includes(option)) { %> checked <% } %>
                          >
                          <label class="form-check-label" for="view_<%= index %>">
                            <%= option %>
                          </label>
                        </div>
                      <% }) %>
                    </div>
                  </div>


                  <!-- Area -->
                  <div class="form-outline mb-4">
                    <label class="form-label" for="area">Floor Area (sq ft)</label>
                    <input type="text" id="area" class="form-control" name="area" value="<%= room.size_sqft || '' %>" />
                  </div>

                  <!-- Price -->
                  <!-- <div class="form-outline mb-4">
                    <label class="form-label" for="price">Price per night</label>
                    <input type="text" id="price" class="form-control" name="price" value="<%= room.price_per_night || '' %>" />
                  </div> -->

                  <div class="form-floating mb-4">
                    <textarea class="form-control border-gray" id="description" rows="4" name="description" style="height: 100px;"><%= room.description %></textarea>
                    <label class="form-label" for="description">Description</label>
                  </div>

                  <!-- Free Cancellation -->
                  <!-- <div class="form-outline mb-4">
                    <label class="form-label" for="free_cancellation_hours">Free cancellation Hours</label>
                    <input type="text" id="free_cancellation_hours" class="form-control" name="free_cancellation_hours" value="<%= room.free_cancellation_hours || 48 %>" />
                  </div> -->
                </div>
              </div>

              <button type="submit" class="btn btn-primary btn-block mb-4">Update Room</button>
              <div id="spiner_loading"></div>
            </form>
          </div>
        </div>
      </div>
    </div>

    <div class="row" id="show_complete_video" style="display: none;">
           <div class="col-lg-12">

          <div class="card">
            <div class="card-body">
              <h5 class="card-title">Rooms Occupancy</h5>

              <table class="table datatable" <% if (occupancies.length !== 0) { %> id="room_option_table" <% } %>>
                <thead>
                  <tr>
                    <th scope="col">#</th>
                    <th scope="col">Room Option Id</th>
                    <th scope="col">Room Id</th>
                    <th scope="col">Occupancy Name</th>
                    <th scope="col">Guest Count</th>
                    <th scope="col">Base Plan</th>
                    <th scope="col">Action</th>
                  </tr>
                </thead>
                <tbody>
                    <% if (occupancies.length === 0) { %>
                        <tr>
                          <td colspan="6" class="text-center">No data available</td>
                        </tr>
                    <% } %>

                    <% occupancies.forEach((item, index) => { %>
                      <tr>
                        <td><%= index + 1 %></td>
                        <td><%= item.room_option_id %></td>
                        <td><%= item.room.room_name_id %></td>
                        <td><%= item.occupancy %></td>
                        <td><%= item.max_guests %></td>
                        <td><%= item.base_meal_plan || "-" %></td>
                        <td>
                          <a href="/portal/room/occupancy/<%= item.id %>" class="btn btn-sm btn-primary">
                            Edit
                          </a>
                         
                          <form action="/portal/room/occupancy/delete/<%= item.id %>" method="POST" style="display:inline;">
                            <button type="submit" class="btn btn-sm btn-danger delete_room_occupancy" data-id="<%= item.id %>">Delete</button>
                          </form>
                        </td>
                      </tr>
                    <% }) %>
                </tbody>
              </table>
            </div>
          </div>

        </div>
       </div>
  </section>
</main><!-- End #main -->

<%- include('../partials/components/footer.ejs'); %>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>


<script>
   $(document).on("click", ".delete_room_occupancy", function (e) {
    e.preventDefault();
    Swal.fire({
      title: 'Are you sure?',
      text: "You won't be able to revert this!",
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#3085d6',
      cancelButtonColor: '#d33',
      confirmButtonText: 'Yes, delete it!'
    }).then((result) => {
      if (result.isConfirmed) {
        var id = $(this).data("id");
        var current_ele = $(this);
        $.ajax({
          type: "POST", // Change to "POST" or "PUT" if needed
          url: `/portal/room/occupancy/delete/${id}`, // Replace with your API endpoint
          success: function (response) {
            // Handle the success response here
            console.log("Success:", response);
            if (response.status == "success") {
              Swal.fire(
                'Deleted!',
                'city has been deleted.',
                'success'
              )
              current_ele.parent().parent().hide();
              location.reload();
            } else {
              console.log("some error occure =====");
            }
          },
          error: function (error) {
            // Handle the error response here
            console.log("Error:", error);
          },
        });
      }
    })
  });

document.addEventListener("DOMContentLoaded", () => {
 $("#complete_video").click(function(){
      $("#show_complete_video").show();
      $("#show_edit_video").hide();
      $("#show_logged_video_users").hide();
    });

    $("#edit_video").click(function(){
      $("#show_complete_video").hide();
      $("#show_logged_video_users").hide();
      $("#show_edit_video").show();
    });

    $("#video_users").click(function(){
      $("#show_complete_video").hide();
      $("#show_edit_video").hide();
      $("#show_logged_video_users").show();
    });

  const galleryInput = document.getElementById("gallery_images_input");
  const previewContainer = document.getElementById("gallery_preview_container");
  const deletedPhotosInput = document.getElementById("deleted_photos");
  const deletedExtrasInput = document.getElementById("deleted_extras");
  let deletedPhotos = [];
  let deletedExtras = [];

  // Store selected files in a DataTransfer object
  let selectedFiles = new DataTransfer();

  // Handle existing gallery image removal
  document.querySelectorAll(".remove-existing-image").forEach(btn => {
    btn.addEventListener("click", function() {
      const photoId = this.dataset.photoId;
      deletedPhotos.push(photoId);
      deletedPhotosInput.value = deletedPhotos.join(",");
      this.closest(".image-container").remove();
      console.log("Marked photo for deletion:", photoId);
    });
  });

  // Handle thumbnail removal
  const removeThumbnailBtn = document.getElementById("remove_thumbnail_btn");
  const removeThumbnailInput = document.getElementById("remove_thumbnail");
  const thumbnailPreview = document.getElementById("thumbnail_preview");
  
  if (removeThumbnailBtn) {
    removeThumbnailBtn.addEventListener("click", () => {
      removeThumbnailInput.value = "1";
      thumbnailPreview.innerHTML = "";
      console.log("Marked thumbnail for deletion");
    });
  }

  // Gallery preview with multiple file support
  galleryInput?.addEventListener("change", (event) => {
    const files = event.target.files;
    if (!files || files.length === 0) return;

    Array.from(files).forEach((file) => {
      selectedFiles.items.add(file);
      
      const reader = new FileReader();
      reader.onload = (e) => {
        const imgDiv = document.createElement("div");
        imgDiv.className = "image-container new-image";
        imgDiv.dataset.filename = file.name;
        imgDiv.innerHTML = `
          <img src="${e.target.result}" alt="Preview" class="rounded-image" />
          <button class="btn btn-danger remove-field" type="button">X</button>
        `;
        previewContainer.appendChild(imgDiv);

        imgDiv.querySelector("button").addEventListener("click", () => {
          const newFileList = new DataTransfer();
          for (let i = 0; i < selectedFiles.files.length; i++) {
            if (selectedFiles.files[i].name !== file.name) {
              newFileList.items.add(selectedFiles.files[i]);
            }
          }
          selectedFiles = newFileList;
          galleryInput.files = selectedFiles.files;
          imgDiv.remove();
        });
      };
      reader.readAsDataURL(file);
    });

    galleryInput.files = selectedFiles.files;
    console.log(`Total new gallery images: ${selectedFiles.files.length}`);
  });

  // Thumbnail preview
  const fileInput = document.getElementById("thumbnail_input");
  if (fileInput) {
    fileInput.addEventListener("change", (event) => {
      const file = event.target.files[0];
      if (!file) return;
      
      // Reset the remove flag when new image is selected
      removeThumbnailInput.value = "0";
      
      const reader = new FileReader();
      reader.onload = (e) => {
        thumbnailPreview.innerHTML = `
          <img src="${e.target.result}" alt="Thumbnail" class="rounded-image" />
          <button class="btn btn-danger remove-field" type="button">X</button>
        `;
        thumbnailPreview.querySelector("button").addEventListener("click", () => {
          fileInput.value = "";
          thumbnailPreview.innerHTML = "";
        });
      };
      reader.readAsDataURL(file);
    });
  }

  // Add Extra functionality
  let extraIndex = <%= room_extras && room_extras.length > 0 ? room_extras.length : 1 %>;
  document.getElementById("add-extra-btn").addEventListener("click", () => {
    const div = document.createElement("div");
    div.classList.add("extra-item", "mb-2");
    div.innerHTML = `
      <input type="text" name="extras[${extraIndex}][name]" placeholder="Extra name" class="form-control d-inline-block w-50" />
      <input type="number" step="0.01" name="extras[${extraIndex}][price]" placeholder="Price" class="form-control d-inline-block w-25" />
      <button type="button" class="btn btn-sm btn-danger remove-extra-btn">×</button>
    `;
    
    div.querySelector(".remove-extra-btn").addEventListener("click", () => {
      div.remove();
    });
    
    document.getElementById("extras-container").appendChild(div);
    extraIndex++;
  });

  // Remove existing extras
  document.querySelectorAll(".remove-extra-btn").forEach(btn => {
    btn.addEventListener("click", function() {
      const extraItem = this.closest(".extra-item");
      const extraId = extraItem.dataset.extraId;
      
      if (extraId) {
        deletedExtras.push(extraId);
        deletedExtrasInput.value = deletedExtras.join(",");
        console.log("Marked extra for deletion:", extraId);
      }
      extraItem.remove();
    });
  });
});
</script>
</body>
</html>